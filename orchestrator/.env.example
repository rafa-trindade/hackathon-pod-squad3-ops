# ==============================================================================
# SQUAD 3 - AMBIENTE DE ORQUESTRAÇÃO E INTEGRAÇÃO (OPS ENGINE)
# Objetivo: Configurações essenciais para o ambiente de orquestração e integração
# ==============================================================================

# --- [1/4] ORIGEM: VPS / MINIO (Bridge/Ingestão) ---
MINIO_ENDPOINT=http://{IP_DA_VPS}:9000
MINIO_ACCESS_KEY=seu_user
MINIO_SECRET_KEY=sua_senha
MINIO_REGION=us-east-1
MINIO_BUCKET_NAME=lake
MINIO_PATH_PREFIX=raw/

# --- [2/4] DESTINO: OCI (Object Storage - S3 Compatible) ---
OCI_S3_ENDPOINT=https://{NAMESPACE}.compat.objectstorage.sa-saopaulo-1.oraclecloud.com
OCI_ACCESS_KEY=sua_key
OCI_SECRET_KEY=sua_secret
OCI_REGION=sa-saopaulo-1
OCI_NAMESPACE=seu_namespace
OCI_BUCKET_NAME=lake

# --- [3/4] ORQUESTRADOR: AIRFLOW (Configurações de Docker) ---
AIRFLOW_IMAGE_TAG=2.7.1-python3.10
AIRFLOW_UID=1000
EXECUTION_ENVIRONMENT=cloud

# Otimização de Engine (DuckDB Spill-to-Disk)
DUCKDB_TEMP_DIR=/tmp/duckdb_process

# Credenciais de acesso à interface Web do Airflow
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=senha_forte

# Instalação dinâmica de dependências
_PIP_ADDITIONAL_REQUIREMENTS=-r /opt/airflow/requirements.txt

# --- [4/4] REPOSITÓRIO CORE (Bootstrap/Sincronização) ---
CORE_REPO_URL=git@github.com:rafa-trindade/hackathon-pod-squad3-core.git
CORE_REPO_DIR=/home/opc/app/hackathon-pod-squad3-core